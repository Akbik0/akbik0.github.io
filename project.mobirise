          },
          "_name": "menu02",
          "_sourceTheme": "startm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"menu menu2\" group=\"Menu\" plugins=\"DropDown, TouchSwipe\" always-top global once=\"menu\" not-draggable position-absolute>\n\t<mbr-parameters>\n\t\t<header>Show/Hide</header>\n\t\t<input type=\"checkbox\" title=\"Logo\" name=\"showLogo\">\n\t\t<input type=\"range\" title=\"Logo Size\" inline name=\"logoSize\" min=\"1\" max=\"5\" step=\"0.1\" value=\"2.1\" condition=\"showLogo\">\n\t\t<input type=\"checkbox\" title=\"Brand Name\" name=\"showBrand\" checked>\n\t\t<input type=\"checkbox\" title=\"Menu Items\" name=\"showItems\" checked>\n\t\t<select title=\"Menu Items Align\" name=\"contentAlign\" condition=\"showItems\">\n\t\t\t<option value=\"1\">Left</option>\n\t\t\t<option value=\"2\" selected>Center</option>\n\t\t\t<option value=\"3\">Right</option>\n\t\t</select>\n\t\t<input type=\"checkbox\" title=\"Icons\" name=\"showIcons\" checked>\n\t\t<select title=\"Amount\" name=\"iconsAmount\" condition=\"showIcons\">\n\t\t\t<option value=\"1\">1</option>\n\t\t\t<option value=\"2\">2</option>\n\t\t\t<option value=\"3\">3</option>\n\t\t\t<option value=\"4\" selected>4</option>\n\t\t</select>\n\t\t<input type=\"color\" title=\"Icons Color\" name=\"iconsColor\" value=\"#000000\" condition=\"showIcons\">\n\t\t<input type=\"checkbox\" title=\"Button\" name=\"showButtons\" checked>\n\t\t<header>Styles</header>\n\t\t<input type=\"checkbox\" title=\"Collapsed\" name=\"collapsed\" condition=\"none\">\n\t\t<input type=\"checkbox\" title=\"Transparent\" name=\"transparent\" checked>\n\t\t<input type=\"checkbox\" title=\"Sticky\" name=\"sticky\" checked>\n\t\t<input type=\"range\" title=\"Opacity\" name=\"opacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.8\" condition=\"transparent\">\n\t\t<input type=\"color\" title=\"Color\" name=\"menuBgColor\" value=\"#ffffff\">\n\t\t<input type=\"color\" title=\"Hamburger\" name=\"hamburgerColor\" value=\"#000000\">\n\t</mbr-parameters>\n\n\t<nav class=\"navbar navbar-dropdown\" mbr-class=\"{'navbar-fixed-top':sticky,\n                     'navbar-expand-lg':!collapsed,\n                     'collapsed':collapsed}\">\n\t\t<div class=\"container\">\n\t\t\t<div class=\"navbar-brand\">\n\t\t\t\t<span mbr-if=\"showLogo\" class=\"navbar-logo\">\n\t\t\t\t\t<a href=\"index.html#top\">\n\t\t\t\t\t\t<img src=\"@PROJECT_PATH@/assets/images/abdulkareem-akbik-3.png\" alt=\"Mobirise Website Builder\" mbr-style=\"{'height': logoSize + 'rem'}\">\n\t\t\t\t\t</a>\n\t\t\t\t</span>\n\t\t\t\t<span mbr-if=\"showBrand\" mbr-buttons mbr-theme-style=\"display-5\" class=\"navbar-caption-wrap\" data-toolbar=\"-mbrBtnMove,-mbrBtnAdd,-mbrBtnRemove,-iconFont\"><a class=\"navbar-caption text-black text-primary\" data-app-selector=\".navbar-caption\" href=\"index.html#header01-4\" data-app-placeholder=\"Type Text\">Abdulkareem Akbik</a></span>\n\t\t\t</div>\n\t\t\t<button class=\"navbar-toggler\" type=\"button\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-target=\"#navbarSupportedContent\" data-bs-target=\"#navbarSupportedContent\" aria-controls=\"navbarNavAltMarkup\" aria-expanded=\"false\" aria-label=\"Toggle navigation\" mbr-if=\"showItems || showIcons || showButtons\">\n\t\t\t\t<div class=\"hamburger\">\n\t\t\t\t\t<span></span>\n\t\t\t\t\t<span></span>\n\t\t\t\t\t<span></span>\n\t\t\t\t\t<span></span>\n\t\t\t\t</div>\n\t\t\t</button>\n\t\t\t<div class=\"collapse navbar-collapse\" id=\"navbarSupportedContent\" mbr-if=\"showItems || showIcons || showButtons\">\n\t\t\t\t<ul mbr-menu class=\"navbar-nav nav-dropdown\" mbr-theme-style=\"display-4\" mbr-if=\"showItems\" mbr-class=\"{'nav-right': !showButtons,'navbar-nav-top-padding': isPublish && !showBrand && !showLogo}\"><li class=\"nav-item\">\n\t\t\t\t\t\t<a class=\"nav-link link text-black text-primary\" href=\"about.html#header16-q\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">About</a>\n\t\t\t\t\t</li>\n\t\t\t\t\t<li class=\"nav-item\">\n\t\t\t\t\t\t<a class=\"nav-link link text-black text-primary\" href=\"gallery.html#gallery04-a\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\" aria-expanded=\"false\">Gallery</a>\n\t\t\t\t\t</li>\n\t\t\t\t\t<li class=\"nav-item\">\n\t\t\t\t\t\t<a class=\"nav-link link text-black text-primary\" href=\"blogs.html#news08-h\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">Blogs</a>\n\t\t\t\t\t</li></ul>\n\t\t\t\t<div class=\"icons-menu\" mbr-if=\"showIcons\">\n\t\t\t\t\t<a class=\"iconfont-wrapper\" href=\"assets/files/Abdulkareem-Akbik-Resume-May2025-Website.pdf\">\n\t\t\t\t\t\t<span mbr-icon class=\"p-2 mbr-iconfont mobi-mbri-file mobi-mbri\"></span>\n\t\t\t\t\t</a>\n\t\t\t\t\t<a class=\"iconfont-wrapper\" href=\"mailto:kareemakbik0@gmail.com\" mbr-if=\"iconsAmount > 1\">\n\t\t\t\t\t\t<span mbr-icon class=\"p-2 mbr-iconfont mobi-mbri-letter mobi-mbri\"></span>\n\t\t\t\t\t</a>\n\t\t\t\t\t<a class=\"iconfont-wrapper\" href=\"https://www.instagram.com/abdulkareemakbik/\" mbr-if=\"iconsAmount > 2\" target=\"_blank\">\n\t\t\t\t\t\t<span mbr-icon class=\"p-2 mbr-iconfont socicon-instagram socicon\"></span>\n\t\t\t\t\t</a>\n\t\t\t\t\t<a class=\"iconfont-wrapper\" href=\"search.html#witsec-search-results-l\" mbr-if=\"iconsAmount > 3\">\n\t\t\t\t\t\t<span mbr-icon class=\"p-2 mbr-iconfont mobi-mbri-search mobi-mbri\"></span>\n\t\t\t\t\t</a>\n\t\t\t\t</div>\n\t\t\t\t<div mbr-if=\"showButtons\" mbr-buttons mbr-theme-style=\"display-4\" class=\"navbar-buttons mbr-section-btn\"><a class=\"btn btn-primary\" href=\"index.html#form02-4\" data-app-placeholder=\"Type Text\">Contact Me!</a></div>\n\t\t\t</div>\n\t\t</div>\n\t</nav>\n</section>",
          "_cid": "uJXdSY7fBn",
          "_anchor": "menu02-j",
          "_protectedParams": [],
          "_global": true,
          "_once": "menu",
          "_params": {}
        },
        {
          "alias": "witsec-search/components",
          "_isSecondary": true,
          "_styles": {
            "& when not (@fullScreen)": {
              "padding-top": "(@paddingTop * 1rem)",
              "padding-bottom": "(@paddingBottom * 1rem)"
            },
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-section-title": {
              "text-align": "center"
            },
            ".mbr-section-text": {
              "text-align": "center"
            },
            "button[type=\"submit\"] when (@isRoundedButtons)": {
              "border-radius": "100px"
            },
            "a[type=\"submit\"], button[type=\"submit\"]": {
              "margin-top": "0"
            },
            ".wsSearchError": {
              "text-align": "center",
              "background-color": "@bgColorError"
            },
            "mark": {
              "padding": "0",
              "color": "inherit",
              "& when not (@searchHighlight)": {
                "background-color": "inherit"
              },
              "& when (@searchHighlight)": {
                "background-color": "@searchHighlightColor"
              },
              "& when (@searchHighlightBold)": {
                "font-weight": "bold"
              }
            },
            ".row .spinner-border, .row .spinner-grow": {
              "width": "32px",
              "color": "@searchSpinnerColor"
            },
            ".gdpr-block": {
              "display": "none"
            }
          },
          "_name": "witsec-search-results",
          "_sourceTheme": "startm5",
          "_customHTML": "<section class=\"witsec-search noindex\" plugins=\"witsec-search\" data-bg-video=\"{{bg.type == 'video'&&bg.value.url}}\" mbr-class=\"{'mbr-fullscreen': fullScreen, 'mbr-parallax-background': bg.parallax}\" data-wssearchtitle=\"{{searchTitle}}\" data-wssearchbodymaxchars=\"{{searchBodyMaxChars}}\" data-wssearchminchars=\"{{searchMinChars}}\" data-wssearchspinner=\"{{searchSpinner}}\" data-wssearchloadmore=\"{{searchLoadMore}}\" data-wssearchloadmorebatch=\"{{searchLoadMoreBatch}}\">\n  <mbr-parameters>\n    <header><a href=\"#\" onclick=\"mbrApp.alertDlg('Outside the search results you can use the following variables:<br><code>{searchString}</code> and <code>{searchTotal}</code><br><br>In the search results you can use the following:<br><code>{index}</code>, <code>{page}</code>, <code>{anchor}</code>, <code>{link}</code>, <code>{score}</code>, <code>{header}</code> and <code>{body}</code>')\">Available Variables</a></header>\n\n    <header>Size</header>\n    <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n    <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"9\" condition=\"fullScreen == false\">\n    <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"2\" condition=\"fullScreen == false\">\n\n    <header>Show/Hide</header>\n    <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n    <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n\n    <header>Search Options</header>\n    <select title=\"Width\" name=\"searchResultsWidth\">\n      <option value=\"8\">Small</option>\n      <option value=\"12\" selected>Large</option>\n    </select>\n    <input type=\"checkbox\" title=\"Show Search Button\" name=\"searchButton\" checked>\n    <input type=\"text\" title=\"Placeholder\" name=\"searchInput\" value=\"Search\" condition=\"searchButton\">\n    <input type=\"text\" title=\"Change Page Title\" name=\"searchTitle\" value=\"| Results for '{searchString}'\">\n    <input type=\"text\" title=\"Minimum Search Word Length\" name=\"searchMinChars\" value=\"3\">\n    <input type=\"color\" title=\"Error BG Color\" name=\"bgColorError\" value=\"#ff4a52\">\n    <input type=\"text\" title=\"Anchor (e.g. #anchorname, leave empty when unsure)\" name=\"anchor\" value>\n\n    <header>Loading Icon</header>\n    <input type=\"checkbox\" title=\"Show Spinner\" name=\"searchSpinner\" checked>\n    <select name=\"searchSpinnerType\" title=\"Type\" condition=\"searchSpinner\">\n      <option value=\"border\" selected>Border</option>\n      <option value=\"grow\">Grow</option>\n    </select>\n    <input type=\"color\" name=\"searchSpinnerColor\" title=\"Color\" value=\"#4479d9\" condition=\"searchSpinner\">\n\n    <header>Search Results</header>\n    <input type=\"text\" title=\"Max Displayed Body Characters\" name=\"searchBodyMaxChars\" value=\"450\">\n    <input type=\"checkbox\" title=\"Highlight Search String\" name=\"searchHighlight\" checked>\n    <input type=\"color\" title=\"Highlight Color\" name=\"searchHighlightColor\" value=\"#ffe161\" condition=\"searchHighlight\">\n    <input type=\"checkbox\" title=\"Bold Search String\" name=\"searchHighlightBold\">\n    <input type=\"checkbox\" title=\"Use 'Load More' Button\" name=\"searchLoadMore\" checked>\n    <input type=\"range\" inline title=\"Batch Size\" name=\"searchLoadMoreBatch\" value=\"7\" min=\"1\" max=\"50\" condition=\"searchLoadMore\">\n\n    <header>Background</header>\n    <fieldset type=\"background\" name=\"bg\" parallax>\n        <input type=\"image\" title=\"Image\" value=\"../_images/background1.jpg\">\n        <input type=\"color\" title=\"Color\" value=\"#a0e1e1\" selected>\n    </fieldset>\n    <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n    <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type !== 'color'\">\n    <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.7\" condition=\"overlay && bg.type !== 'color'\">\n  </mbr-parameters>\n\n  <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type!== 'color'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\"></div>\n\n  <div class=\"container\">\n    <div class=\"row justify-content-center\">\n        <div class=\"title col-md-12\">\n            <h3 class=\"mbr-section-title mbr-fonts-style align-center mb-4\" mbr-if=\"showTitle\" data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-5\">\n                <b>Search this website</b></h3>\n            <p class=\"mbr-section-text align-center mbr-fonts-style mb-4\" mbr-if=\"showText\" data-app-selector=\".mbr-section-text\" mbr-theme-style=\"display-7\">\n                Enter one or more keywords in the field below and search away!<br></p>\n        </div>\n    </div>\n\n    <div class=\"row\">\n        <div class=\"col-lg-8 mx-auto\">\n            <form class=\"mbr-form\" action=\"{{anchor}}\">\n                <div class=\"row\">\n                    <div class=\"col-lg col-md col-12\">\n                        <input type=\"text\" name=\"q\" placeholder=\"{{searchInput}}\" class=\"form-control wsSearchInput\" minlength=\"{{searchMinChars}}\" required>\n                    </div>\n                    <div mbr-if=\"searchButton\" class=\"mbr-section-btn col-md-auto col\" mbr-buttons=\"true\" mbr-theme-style=\"display-4\" data-toolbar=\"-mbrBtnMove,-mbrLink,-mbrBtnRemove,-mbrBtnAdd\"><a type=\"submit\" class=\"btn btn-primary\" data-app-placeholder=\"Type Text\">Search</a></div>\n                </div>\n            </form>\n        </div>\n    </div>\n\n    <div class=\"wsSearchSpinner row justify-content-center mt-4\" mbr-if=\"searchSpinner\" mbr-class=\"{'d-none': isPublish}\">\n      <div class=\"spinner-{{searchSpinnerType}}\">\n        <span class=\"sr-only\"></span>\n      </div>\n    </div>\n\n    <div class=\"row justify-content-center mt-4\">\n      <div class=\"col-lg-{{searchResultsWidth}}\">\n        <p class=\"wsSearchResultsFor mbr-fonts-style mb-4\" data-app-selector=\".wsSearchResultsFor\" mbr-theme-style=\"display-7\" mbr-class=\"{'d-none': isPublish}\">\n          Found {searchTotal} result(s) for '{searchString}'.\n        </p>\n\n        <p class=\"wsSearchNoResults mbr-fonts-style mb-4\" data-app-selector=\".wsSearchNoResults\" mbr-theme-style=\"display-7\" mbr-class=\"{'d-none': isPublish}\">\n          No results were found for '{searchString}'.\n        </p>\n\n        <div class=\"wsSearchResults\" mbr-class=\"{'d-none': isPublish}\">\n          <div class=\"wsSearchResultTemplate mb-4\">\n            <p class=\"wsSearchResultTemplateHeader mb-0 mbr-fonts-style\" data-app-selector=\".wsSearchResultTemplateHeader\" mbr-theme-style=\"display-7\">{index}.&nbsp;<a data-href=\"{link}\" style=\"font-weight: bold;\">{header:This <mark>dummy</mark> header will be replaced.}</a></p>\n            <p class=\"wsSearchResultTemplateBody mb-0 mbr-fonts-style\" data-app-selector=\".wsSearchResultTemplateBody\" mbr-theme-style=\"display-7\">{body:This is just some example text that helps you understand what your search results will look like. In this example, we're searching for the word '<mark>dummy</mark>', which is highlighted, if you have highlighting enabled. This body tag will be replaced with the actual body text of a search result, so you don't have to change this text.}<br><a data-href=\"{link}\" class=\"text-primary\"><i>{page:example.html}</i></a></p>\n          </div>\n        </div>\n\n        <div class=\"wsSearchLoadMore\" mbr-class=\"{'d-none': isPublish}\" mbr-if=\"searchLoadMore\">\n          <div class=\"mbr-section-btn col-md-auto col text-center\" mbr-buttons=\"true\" mbr-theme-style=\"display-4\" data-toolbar=\"-mbrBtnMove,-mbrLink,-mbrBtnRemove,-mbrBtnAdd\"><a class=\"btn wsSearchLoadMoreButton btn-primary\" data-app-placeholder=\"Type Text\">Load More</a></div>\n        </div>\n\n        <div mbr-text class=\"wsSearchError mt-4 alert alert-danger col-12 mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-edit=\"content\" data-app-selector=\".wsSearchError\" mbr-class=\"{'d-none': isPublish}\">\n          An error occured. Please try again.</div>\n      </div>\n    </div>\n\n  </div>\n</section>",
          "_cid": "uK08hzUv2G",
          "_anchor": "witsec-search-results-l",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
